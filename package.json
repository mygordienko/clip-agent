    "url": "git+https://github.com/mygordienko/clip-agent.git"
  },
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "start-ubuntu": "electron-forge start -- --no-sandbox --ozone-platform=x11",
